import java.util.*;

public class Solution {

    public static void main(String[] args) {
        Scanner scan = new Scanner(System.in);
        String s = scan.nextLine();
        
        // Trim leading/trailing whitespace to handle edge cases
        s = s.trim();
        
        // If the string is empty after trimming, the count is 0
        if (s.length() == 0) {
            System.out.println(0);
        } else {
            // Split by any character that is NOT an English letter
            // [^A-Za-z]+ means "one or more non-alphabetic characters"
            String[] tokens = s.split("[^A-Za-z]+");
            
            System.out.println(tokens.length);
            for (String token : tokens) {
                System.out.println(token);
            }
        }
        scan.close();
    }
}
